{
  "lastChangelogVersion": "0.70.2",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "packages": [
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:pi-powerline-footer"
  ],
  "hideThinkingBlock": true,
  "transport": "auto",
  "powerline": {
    "preset": "minimal",
    "customItems": [
      {
        "id": "model",
        "statusKey": "model-status",
        "position": "left"
      },
      {
        "id": "reasoning",
        "statusKey": "reasoning-status",
        "position": "left"
      },
      {
        "id": "codex",
        "statusKey": "codex-status",
        "position": "right"
      }
    ]
  },
  "workingVibe": "theme",
  "quietStartup": true,
  "showHardwareCursor": false,
  "enabledModels": [
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.5",
    "opencode-go/kimi-k2.6",
    "opencode-go/glm-5.1"
  ]
}