{
  "lastChangelogVersion": "0.70.2",
  "defaultProvider": "cursor",
  "defaultModel": "gpt-5.5-high",
  "defaultThinkingLevel": "high",
  "packages": [
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "npm:pi-powerline-footer",
    "npm:@plannotator/pi-extension",
    "npm:@netandreus/pi-cursor-provider"
  ],
  "hideThinkingBlock": true,
  "transport": "auto",
  "powerline": {
    "preset": "minimal",
    "customItems": [
      {
        "id": "model",
        "statusKey": "model-status",
        "position": "left"
      },
      {
        "id": "reasoning",
        "statusKey": "reasoning-status",
        "position": "left"
      },
      {
        "id": "codex",
        "statusKey": "codex-status",
        "position": "right"
      }
    ]
  },
  "workingVibe": "theme",
  "showLastPrompt": false,
  "quietStartup": true,
  "showHardwareCursor": false,
  "enabledModels": [
    "cursor/gpt-5.5-extra-high",
    "cursor/gpt-5.5-high",
    "cursor/gpt-5.5-medium",
    "cursor/composer-2-fast"
  ]
}