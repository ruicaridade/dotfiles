# Ghostty Configuration

# Theme
theme = rose-pine

# Font
font-family = JetBrainsMono Nerd Font
font-size = 20
font-thicken = true
font-thicken-strength = 50

# Line height (1.3)
adjust-cell-height = 25%

# Window decorations - remove title bar, buttons, etc.
window-decoration = none

# Window padding
window-padding-x = 12
window-padding-y = 12
